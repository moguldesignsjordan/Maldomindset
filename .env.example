# PayPal credentials — get these from https://developer.paypal.com/dashboard/applications
# Use Sandbox values for testing, Live values for real payments.

# Public client ID, exposed to the browser by the PayPal JS SDK (Vite requires the VITE_ prefix)
VITE_PAYPAL_CLIENT_ID=

# Same client ID, used server-side by the /api/paypal serverless functions
PAYPAL_CLIENT_ID=

# Secret — server-side only, never expose to the browser
PAYPAL_CLIENT_SECRET=

# https://api-m.sandbox.paypal.com for testing, https://api-m.paypal.com for live
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
